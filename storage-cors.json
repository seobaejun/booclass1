[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "OPTIONS"],
    "maxAgeSeconds": 3600,
    "responseHeader": [
      "Content-Type",
      "Content-Length",
      "Content-Disposition",
      "Content-Range",
      "Authorization",
      "x-goog-hash",
      "x-goog-generation",
      "x-goog-metageneration",
      "x-goog-storage-class"
    ]
  }
]
